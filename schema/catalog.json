  "$defs": {
    "BodyModificationCriterionInput": {
      "kind": "input",
      "fields": [
        {
          "name": "location",
          "type": "String",
          "required": false
        },
        {
          "name": "description",
          "type": "String",
          "required": false
        },
        {
          "name": "modifier",
          "type": "CriterionModifier!",
          "required": true
        }
      ]
    },
    "BreastTypeCriterionInput": {
      "kind": "input",
      "fields": [
        {
          "name": "value",
          "type": "BreastTypeEnum",
          "required": false
        },
        {
          "name": "modifier",
          "type": "CriterionModifier!",
          "required": true
        }
      ]
    },
    "BreastTypeEnum": {
      "kind": "enum",
      "values": [
        {
          "value": "NATURAL"
        },
        {
          "value": "FAKE"
        },
        {
          "value": "NA"
        }
      ]
    },
    "CriterionModifier": {
      "kind": "enum",
      "values": [
        {
          "value": "EQUALS",
          "description": "="
        },
        {
          "value": "NOT_EQUALS",
          "description": "!="
        },
        {
          "value": "GREATER_THAN",
          "description": "\u003e"
        },
        {
          "value": "LESS_THAN",
          "description": "\u003c"
        },
        {
          "value": "IS_NULL",
          "description": "IS NULL"
        },
        {
          "value": "NOT_NULL",
          "description": "IS NOT NULL"
        },
        {
          "value": "INCLUDES_ALL",
          "description": "INCLUDES ALL"
        },
        {
          "value": "INCLUDES"
        },
        {
          "value": "EXCLUDES"
        }
      ]
    },
    "DateCriterionInput": {
      "kind": "input",
      "fields": [
        {
          "name": "value",
          "type": "Date!",
          "required": true
        },
        {
          "name": "modifier",
          "type": "CriterionModifier!",
          "required": true
        }
      ]
    },
    "EditQueryInput": {
      "kind": "input",
      "fields": [
        {
          "name": "user_id",
          "type": "ID",
          "required": false,
          "description": "Filter by user id"
        },
        {
          "name": "status",
          "type": "VoteStatusEnum",
          "required": false,
          "description": "Filter by status"
        },
        {
          "name": "operation",
          "type": "OperationEnum",
          "required": false,
          "description": "Filter by operation"
        },
        {
          "name": "vote_count",
          "type": "IntCriterionInput",
          "required": false,
          "description": "Filter by vote count"
        },
        {
          "name": "applied",
          "type": "Boolean",
          "required": false,
          "description": "Filter by applied status"
        },
        {
          "name": "target_type",
          "type": "TargetTypeEnum",
          "required": false,
          "description": "Filter by target type"
        },
        {
          "name": "target_id",
          "type": "ID",
          "required": false,
          "description": "Filter by target id"
        },
        {
          "name": "is_favorite",
          "type": "Boolean",
          "required": false,
          "description": "Filter by favorite status"
        },
        {
          "name": "voted",
          "type": "UserVotedFilterEnum",
          "required": false,
          "description": "Filter by user voted status"
        },
        {
          "name": "is_bot",
          "type": "Boolean",
          "required": false,
          "description": "Filter to bot edits only"
        },
        {
          "name": "include_user_submitted",
          "type": "Boolean",
          "required": false,
          "description": "Filter out user's own edits"
        },
        {
          "name": "page",
          "type": "Int!",
          "required": false,
          "default": "1"
        },
        {
          "name": "per_page",
          "type": "Int!",
          "required": false,
          "default": "25"
        },
        {
          "name": "direction",
          "type": "SortDirectionEnum!",
          "required": false,
          "default": "DESC"
        },
        {
          "name": "sort",
          "type": "EditSortEnum!",
          "required": false,
          "default": "CREATED_AT"
        }
      ]
    },
    "EditSortEnum": {
      "kind": "enum",
      "values": [
        {
          "value": "CREATED_AT"
